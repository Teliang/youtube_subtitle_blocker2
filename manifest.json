{
  "manifest_version": 3,
  "name": "YouTube Subtitle Blocker2",
  "version": "2.1",
  "permissions": [
    "tabs","storage"
  ],
  "action": {"default_icon": "icons/icon48.png"},
  "background": {
    "scripts": [
      "background.js"
    ],
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "youtubesubtitle@blocker2.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "48": "icons/icon48.png"
  }
}
